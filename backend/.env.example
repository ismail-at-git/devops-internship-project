NODE_ENV=development
PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:3000

# Docker Compose: `PORT` is overridden to 5000 in docker-compose.yml.
# For Atlas from containers, allow your IP (or 0.0.0.0/0 for dev) in Atlas Network Access.
